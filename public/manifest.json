{
  "manifest_version": 3,
  "name": "PagePulse",
  "version": "1.0.0",
  "description": "Continuously monitor specific webpages and instantly alert when a defined change occurs.",
  "action": {
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.ts"],
      "run_at": "document_end"
    }
  ],
  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "scripting",
    "offscreen"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
